---
import BaseLayout from "../../../layouts/base-layout.astro";
import { SUPPORTED_LANGUAGES, type Language } from "../../../lib/i18n";
import { getLibrarySurfaceGroups } from "../../../lib/library";

export function getStaticPaths() {
  return SUPPORTED_LANGUAGES.map((language) => ({ params: { lang: language } }));
}

const language = Astro.params.lang as Language;
const copy = {
  zh: {
    title: "资料库",
    body: "长期可回访的工具、阅读、当前状态、模式和书签。当前条目都是清晰标记的示例种子。",
    demo: "示例种子",
    visit: "打开资源",
  },
  en: {
    title: "Library",
    body: "Long-lived inventories for uses, reading, current focus, patterns, and bookmarks. Current entries are clearly marked demo seeds.",
    demo: "Demo seed",
    visit: "Open resource",
  },
}[language];
const groups = getLibrarySurfaceGroups(language);
---

<BaseLayout language={language} title={copy.title}>
  <section class="page-section library-hub">
    <h1>{copy.title}</h1>
    <p>{copy.body}</p>

    <div class="library-groups">
      {
        groups.map((group) => (
          <section class="library-group" id={group.id} aria-labelledby={`${group.id}-title`}>
            <div class="library-group-header">
              <h2 id={`${group.id}-title`}>{group.title}</h2>
              <p>{group.body}</p>
            </div>
            <div class="content-list">
              {group.items.map((item) => (
                <article class="content-card library-item" id={item.key}>
                  <p class="meta">{copy.demo}</p>
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                  <div class="tag-list" aria-label={language === "zh" ? "标签" : "Tags"}>
                    {item.tags.map((tag) => (
                      <span>{tag}</span>
                    ))}
                  </div>
                  {item.url && (
                    <a class="text-link" href={item.url} rel="noreferrer" target="_blank">
                      {copy.visit}
                    </a>
                  )}
                </article>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </section>
</BaseLayout>
