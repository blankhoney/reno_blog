---
import BaseLayout from "../../../layouts/base-layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import ProjectCaseStudy from "../../../components/ProjectCaseStudy.astro";
import { buildContentIndex } from "../../../lib/content-index";
import { getAllLibraryItems } from "../../../lib/library";
import { getRelatedContent } from "../../../lib/relations";
import { getSectionNavigation } from "../../../lib/sections";

type Props = {
  entry: CollectionEntry<"projects">;
};

export async function getStaticPaths() {
  const entries = await getCollection("projects", (entry) => entry.data.status === "published");

  return entries.map((entry) => ({
    params: {
      lang: entry.data.language,
      slug: entry.data.translationKey,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const sectionNavigation = getSectionNavigation(entry.data.language, "projects");
const [writing, notes, projects] = await Promise.all([
  getCollection("writing"),
  getCollection("notes"),
  getCollection("projects"),
]);
const library = getAllLibraryItems().map((item) => ({
  body: item.summary,
  data: {
    date: new Date(item.date),
    language: item.language,
    status: item.status,
    summary: item.summary,
    tags: item.tags,
    title: item.title,
    translationKey: item.key,
  },
}));
const contentIndex = buildContentIndex([
  { section: "writing", entries: writing },
  { section: "notes", entries: notes },
  { section: "projects", entries: projects },
  { section: "library", entries: library },
]);
const relatedItems = getRelatedContent(
  contentIndex.map((item) => ({
    ...item,
    related: item.relationKeys,
  })),
  `projects:${entry.data.translationKey}`,
);
---

<BaseLayout
  language={entry.data.language}
  title={entry.data.name}
  description={entry.data.summary}
>
  <ProjectCaseStudy
    language={entry.data.language}
    name={entry.data.name}
    relatedItems={relatedItems}
    role={entry.data.role}
    sectionNavigation={sectionNavigation}
    summary={entry.data.summary}
    tags={entry.data.tags}
    techStack={entry.data.techStack}
  >
    <Content />
  </ProjectCaseStudy>
</BaseLayout>
