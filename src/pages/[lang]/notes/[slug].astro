---
import BaseLayout from "../../../layouts/base-layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import { getSectionNavigation } from "../../../lib/sections";

type Props = {
  entry: CollectionEntry<"notes">;
};

export async function getStaticPaths() {
  const entries = await getCollection("notes", (entry) => entry.data.status === "published");

  return entries.map((entry) => ({
    params: {
      lang: entry.data.language,
      slug: entry.data.translationKey,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const sectionNavigation = getSectionNavigation(entry.data.language, "notes");
const breadcrumbLabel = entry.data.language === "zh" ? "内容位置" : "Content location";
---

<BaseLayout
  language={entry.data.language}
  title={entry.data.title}
  description={entry.data.summary}
>
  <article class="content-detail compact-detail">
    <nav class="breadcrumb" aria-label={breadcrumbLabel}>
      <a href={sectionNavigation.href}>{sectionNavigation.returnLabel}</a>
    </nav>
    <p class="eyebrow">{entry.data.date.toLocaleDateString(entry.data.language)}</p>
    <h1>{entry.data.title}</h1>
    {entry.data.summary && <p class="lead">{entry.data.summary}</p>}
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>
