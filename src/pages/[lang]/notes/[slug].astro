---
import BaseLayout from "../../../layouts/base-layout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";
import ReaderShell from "../../../components/ReaderShell.astro";
import { getPublishedEntriesForLanguage } from "../../../lib/content";
import {
  calculateReadingTime,
  getAdjacentReaderEntries,
} from "../../../lib/reader";
import { getSectionNavigation } from "../../../lib/sections";

type Props = {
  entry: CollectionEntry<"notes">;
};

export async function getStaticPaths() {
  const entries = await getCollection("notes", (entry) => entry.data.status === "published");

  return entries.map((entry) => ({
    params: {
      lang: entry.data.language,
      slug: entry.data.translationKey,
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const sectionNavigation = getSectionNavigation(entry.data.language, "notes");
const entries = getPublishedEntriesForLanguage(
  (await getCollection("notes")).map((item) => ({
    ...item,
    slug: item.data.translationKey,
  })),
  entry.data.language,
);
const adjacent = getAdjacentReaderEntries(
  entries.map((item) => ({
    slug: item.slug,
    title: item.data.title,
  })),
  entry.data.translationKey,
);
const minutes = calculateReadingTime(entry.body ?? entry.data.summary ?? "", entry.data.language);
---

<BaseLayout
  language={entry.data.language}
  title={entry.data.title}
  description={entry.data.summary}
>
  <ReaderShell
    date={entry.data.date}
    headings={headings}
    language={entry.data.language}
    minutes={minutes}
    next={adjacent.next}
    previous={adjacent.previous}
    sectionNavigation={sectionNavigation}
    summary={entry.data.summary}
    tags={entry.data.tags}
    title={entry.data.title}
    variant="notes"
  >
    <Content />
  </ReaderShell>
</BaseLayout>
