---
import type { Language } from "../lib/i18n";
import {
  formatReadingTime,
  shouldShowTableOfContents,
  type ReaderHeading,
  type ReaderNavEntry,
} from "../lib/reader";
import type { SectionNavigation } from "../lib/sections";

type Props = {
  date: Date;
  headings?: ReaderHeading[];
  language: Language;
  minutes: number;
  next?: ReaderNavEntry;
  previous?: ReaderNavEntry;
  sectionNavigation: SectionNavigation;
  summary?: string;
  tags?: string[];
  title: string;
  variant?: "writing" | "notes";
};

const {
  date,
  headings = [],
  language,
  minutes,
  next,
  previous,
  sectionNavigation,
  summary,
  tags = [],
  title,
  variant = "writing",
} = Astro.props;
const breadcrumbLabel = language === "zh" ? "内容位置" : "Content location";
const metadataLabel = language === "zh" ? "阅读信息" : "Reading metadata";
const tocLabel = language === "zh" ? "目录" : "Contents";
const tagsLabel = language === "zh" ? "标签" : "Tags";
const previousLabel = language === "zh" ? "上一篇" : "Previous";
const nextLabel = language === "zh" ? "下一篇" : "Next";
const showToc = shouldShowTableOfContents(headings);
const usefulHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<article class:list={["reader-shell", `reader-shell-${variant}`]}>
  <nav class="breadcrumb" aria-label={breadcrumbLabel}>
    <a href={sectionNavigation.href}>{sectionNavigation.returnLabel}</a>
  </nav>

  <header class="reader-header">
    <p class="eyebrow">{sectionNavigation.label}</p>
    <h1>{title}</h1>
    {summary && <p class="lead">{summary}</p>}
    <dl class="reader-meta" aria-label={metadataLabel}>
      <div>
        <dt>{language === "zh" ? "发布" : "Published"}</dt>
        <dd>{date.toLocaleDateString(language)}</dd>
      </div>
      <div>
        <dt>{language === "zh" ? "时间" : "Time"}</dt>
        <dd>{formatReadingTime(minutes, language)}</dd>
      </div>
    </dl>
    {
      tags.length > 0 && (
        <div class="tag-list" aria-label={tagsLabel}>
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      )
    }
  </header>

  {
    showToc && (
      <nav class="reader-toc" aria-label={tocLabel}>
        <p>{tocLabel}</p>
        <ol>
          {usefulHeadings.map((heading) => (
            <li class={`toc-depth-${heading.depth}`}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )
  }

  <div class="prose">
    <slot />
  </div>

  <div class="reader-demo-slot">
    <slot name="demo" />
  </div>

  {
    (previous || next) && (
      <footer class="reader-footer" aria-label={language === "zh" ? "相邻内容" : "Adjacent content"}>
        {previous && (
          <a href={`${sectionNavigation.href}${previous.slug}/`}>
            <span>{previousLabel}</span>
            {previous.title}
          </a>
        )}
        {next && (
          <a href={`${sectionNavigation.href}${next.slug}/`}>
            <span>{nextLabel}</span>
            {next.title}
          </a>
        )}
      </footer>
    )
  }
</article>

