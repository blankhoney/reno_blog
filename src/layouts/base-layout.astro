---
import { ClientRouter } from "astro:transitions";
import { getCollection } from "astro:content";
import CommandPalette from "../components/CommandPalette.astro";
import {
  DEFAULT_LANGUAGE,
  getNavigation,
  isSupportedLanguage,
  type Language,
} from "../lib/i18n";
import { buildCommandPaletteItems } from "../lib/command-palette";
import { buildContentIndex } from "../lib/content-index";
import { getAllLibraryItems } from "../lib/library";
import { getMotionInitScript } from "../lib/motion";
import { getThemeInitScript, getThemeOptions } from "../lib/theme";
import { site } from "../config/site";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  language?: string;
};

const requestedLanguage = Astro.props.language;
const language: Language =
  requestedLanguage && isSupportedLanguage(requestedLanguage)
    ? requestedLanguage
    : DEFAULT_LANGUAGE;
const title = Astro.props.title ? `${Astro.props.title} | ${site.name}` : site.name;
const description = Astro.props.description ?? site.description[language];
const navigation = getNavigation(language);
const alternateLanguage = language === "zh" ? "en" : "zh";
const alternatePath = Astro.url.pathname.replace(
  new RegExp(`^/${language}(?=/|$)`),
  `/${alternateLanguage}`,
);
const themeOptions = getThemeOptions(language);
const themeLabel = language === "zh" ? "主题" : "Theme";
const [writing, notes, projects] = await Promise.all([
  getCollection("writing"),
  getCollection("notes"),
  getCollection("projects"),
]);
const library = getAllLibraryItems().map((item) => ({
  body: item.summary,
  data: {
    date: new Date(item.date),
    language: item.language,
    status: item.status,
    summary: item.summary,
    tags: item.tags,
    title: item.title,
    translationKey: item.key,
  },
}));
const commandItems = buildCommandPaletteItems(
  language,
  buildContentIndex([
    { section: "writing", entries: writing },
    { section: "notes", entries: notes },
    { section: "projects", entries: projects },
    { section: "library", entries: library },
  ]),
);
---

<!doctype html>
<html lang={language} transition:name="root" transition:animate="fade">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline set:html={getThemeInitScript()} />
    <script is:inline set:html={getMotionInitScript()} />
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">{language === "zh" ? "跳到正文" : "Skip to content"}</a>
    <header class="site-header">
      <a class="brand" href={`/${language}/`}>{site.name}</a>
      <nav class="site-nav" aria-label={language === "zh" ? "主导航" : "Main navigation"}>
        {
          navigation.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))
        }
      </nav>
      <div class="header-actions">
        <div class="theme-toggle" role="group" aria-label={themeLabel}>
          {
            themeOptions.map((option) => (
              <button
                aria-pressed={option.value === "system" ? "true" : "false"}
                data-theme-option={option.value}
                type="button"
              >
                {option.label}
              </button>
            ))
          }
        </div>
        <a class="language-toggle" href={alternatePath}>
          {alternateLanguage === "zh" ? "中文" : "EN"}
        </a>
        <CommandPalette commands={commandItems} language={language} />
      </div>
    </header>
    <main id="content" tabindex="-1" transition:animate="slide">
      <slot />
    </main>
  </body>
</html>
